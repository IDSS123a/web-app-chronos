# GEMINI_API_KEY: Rezervisano za buduće AI funkcionalnosti (van opsega — vidi CONSTITUTION.md §8).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: URL na kojem je aplikacija hostovana.
APP_URL="MY_APP_URL"

# ── Supabase (server strana — Express backend, service role, NIKAD u frontend bundle) ──
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your_service_role_key_here"

# ── Supabase (klijentska strana — Vite izlaže samo VITE_ prefiksirane varijable) ──
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your_anon_or_publishable_key_here"

# ── Express server port (dev) — deliberately not named PORT, see server/index.ts ──
API_PORT=3001

# ── Resend (email podsjetnici — koristi se od Sprint 06) ──
RESEND_API_KEY="your_resend_key_here"
RESEND_FROM_EMAIL="onboarding@resend.dev"
